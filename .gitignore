# ==========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db

# IDEs (VS Code, PyCharm, WebStorm)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
